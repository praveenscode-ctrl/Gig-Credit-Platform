# ================================
# GIGCREDIT .gitignore
# ================================

# Git backup (local only, never push)
.git_backup/

# Python
__pycache__/
*.pyc
*.pyo
.env
venv/
*.egg-info/
.pytest_cache/
dist/
build/

# Flutter
app/.dart_tool/
app/.packages
app/build/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
*.tmp

# ML large files (if any exceed 50MB)
# ml_pipeline/data/generated/*.csv

# Environment secrets
.env
.env.local
.env.production

# NEVER ignore these:
# contracts/*.json
# app/assets/config/*.json
# app/lib/scoring/models/*.dart
# demo_data/**
# artifact_manifest.json

# Personal & User-specified Exclusions
photos/
# NOTE: /report/ only excludes top-level report folders, NOT app/lib source code
/report/
specification folders_new/
test_pdfs/
app/assets/constants/golden_100.json
/gitignore folders and files/
verify_dynamic_pipeline.py
backend/audit_logs.json
# Ignore loose image files but keep tracked app assets
*.jpg
*.jpeg
*.webp
*.png
!app/assets/images/app_logo.png
!app/android/app/src/main/res/mipmap-hdpi/ic_launcher.png
!app/android/app/src/main/res/mipmap-mdpi/ic_launcher.png
